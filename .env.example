# ── LLM / OpenAI ──────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=   # opcional, deja sin definir para OpenAI directo

# ── Thresholds del router ─────────────────────────────────────
# Score mínimo para que el RAG considere que tiene información suficiente (0.0 - 1.0)
CONFIDENCE_THRESHOLD=0.65
# Score mínimo para que el router responda automáticamente en lugar de escalar
MINIMUM_SCORE=0.60

# ── Servidor ──────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Embeddings (multilingüe recomendado para docs en español) ─
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ── Almacenamiento ────────────────────────────────────────────
DOCS_DIR=./docs
CHROMA_DIR=./data/chroma_db
COLLECTION_NAME=soporte_docs

# ── Chunking ──────────────────────────────────────────────────
CHUNK_SIZE=400
CHUNK_OVERLAP=80

# ── Retrieval ─────────────────────────────────────────────────
TOP_K=4

# ── Logging ───────────────────────────────────────────────────
# Nivel mínimo: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# true → JSON estructurado por stdout (prod/Docker/Loki/ELK).
# false → consola coloreada legible (dev local).
LOG_JSON=false
